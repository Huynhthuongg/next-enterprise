################################################################################
# OpenTelemetry Configuration for Kubiks Observability Platform
################################################################################
# 
# Kubiks automatically collects telemetry data from your Next.js application
# and provides insights into performance, errors, and user behavior.
#
# Required environment variables:

# Kubiks OTLP Endpoint - where telemetry data is sent
OTEL_EXPORTER_OTLP_ENDPOINT=https://ingest.kubiks.app

# Protocol for sending data (HTTP with Protocol Buffers)
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Authentication header with your Kubiks API key
# Get your API key from: https://app.kubiks.ai/settings/api-keys
OTEL_EXPORTER_OTLP_HEADERS=x-kubiks-key=YOUR_API_KEY

# Service name - identifies your application in Kubiks dashboards
OTEL_SERVICE_NAME=next-enterprise

# Optional: Set sampling rate (0.0 to 1.0, default: 1.0 = 100%)
# Use 0.1 for 10% sampling to reduce costs in high-traffic applications
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=1.0

# Optional: Log level for OpenTelemetry (DEBUG, INFO, WARN, ERROR)
# OTEL_LOG_LEVEL=INFO
